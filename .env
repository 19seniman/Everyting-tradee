# Base URL API
BASE_URL=https://hp-sbt.everything.co

# Bearer/auth token dari header "token" pada request browser
# JANGAN dibagikan atau di-commit ke git!
TOKEN=isi_token_kamu_di_sini

# Seluruh isi header "cookie" dari request browser (termasuk aws-waf-token, _vid_t, dll)
COOKIE=isi_cookie_lengkap_di_sini

# Header "device-id" dari request browser
DEVICE_ID=isi_device_id_di_sini

# Header "visitor-id" dari request browser
VISITOR_ID=isi_visitor_id_di_sini
