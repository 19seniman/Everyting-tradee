# Base URL API (sama untuk semua akun)
BASE_URL=https://hp-sbt.everything.co

# ============================================================
# AKUN 1
# Ambil nilai TOKEN, COOKIE, DEVICE_ID, VISITOR_ID dari DevTools
# (lihat header request seperti /api/etoken/point/account)
# ============================================================
ACCOUNT_1_LABEL=Akun Utama
ACCOUNT_1_TOKEN=isi_token_akun_1
ACCOUNT_1_COOKIE=isi_cookie_lengkap_akun_1
ACCOUNT_1_DEVICE_ID=isi_device_id_akun_1
ACCOUNT_1_VISITOR_ID=isi_visitor_id_akun_1

# ============================================================
# AKUN 2 (opsional — hapus blok ini kalau hanya punya 1 akun,
# atau tambah ACCOUNT_3_*, ACCOUNT_4_*, dst. untuk lebih banyak)
# ============================================================
ACCOUNT_2_LABEL=Akun Kedua
ACCOUNT_2_TOKEN=isi_token_akun_2
ACCOUNT_2_COOKIE=isi_cookie_lengkap_akun_2
ACCOUNT_2_DEVICE_ID=isi_device_id_akun_2
ACCOUNT_2_VISITOR_ID=isi_visitor_id_akun_2
